# Copy file này thành ".env" rồi điền giá trị thật trước khi chạy:
#   cp .env.example .env
#   docker compose -f docker-compose.prod.yml up -d --build

# Mật khẩu tài khoản "sa" của SQL Server (bắt buộc: chữ hoa, chữ thường, số, ký tự đặc biệt, >= 8 ký tự)
SA_PASSWORD=ChangeMe_Strong_Password123!

# Khoá ký JWT - chuỗi ngẫu nhiên, ít nhất 32 ký tự
JWT_SECRET=ChangeMe_jwt_secret_key_at_least_32_chars_long

# Domain hoặc IP public dùng để truy cập (vd. http://123.45.67.89 hoặc https://demo.example.com)
PUBLIC_URL=http://localhost

# Hiển thị Swagger UI tại /swagger (true để khách kiểm thử API, false khi production thật)
ENABLE_SWAGGER=true

# Seed dữ liệu mẫu (phòng ban/nhân viên/dự án demo + 3 tài khoản admin/manager/employee) khi khởi động lần đầu
SEED_ENABLED=true
